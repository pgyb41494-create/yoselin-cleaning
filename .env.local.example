# ─────────────────────────────────────────────
# Firebase — from Firebase Console → Project Settings → Your Apps → Config
# ─────────────────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id_here

# Admin Gmail addresses — comma-separated; first is primary
# Set `NEXT_PUBLIC_ADMIN_EMAIL` to the primary admin (used by server code)
# Optionally list all admin addresses in `NEXT_PUBLIC_ADMIN_EMAILS` (comma-separated)
NEXT_PUBLIC_ADMIN_EMAIL=cardonayoselin422@gmail.com
NEXT_PUBLIC_ADMIN_EMAILS=cardonayoselin422@gmail.com,pgyb41494@gmail.com

# ─────────────────────────────────────────────
# EmailJS (optional — for email & SMS notifications)
# Sign up free at https://www.emailjs.com
# Create 3 templates:
#   1. notify_admin   → To: {{admin_email}}, Subject: {{subject}}, Body: {{message}}
#   2. notify_customer → To: {{to_email}}, Subject: {{subject}}, Body: Hi {{to_name}},\n\n{{message}}
#   3. password_reset  → To: {{to_email}}, Subject: {{subject}}, Body: includes {{reset_link}}
# ─────────────────────────────────────────────
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=WVsGhoIxLSrw4Tie5
NEXT_PUBLIC_EMAILJS_SERVICE_ID=service_80bcycc
NEXT_PUBLIC_EMAILJS_ADMIN_TEMPLATE=template_5v1zbyx
NEXT_PUBLIC_EMAILJS_CUSTOMER_TEMPLATE=template_hect8cv
NEXT_PUBLIC_EMAILJS_PASSWORD_RESET_TEMPLATE=template_027md2n

# Optional second EmailJS account/service for password reset only
